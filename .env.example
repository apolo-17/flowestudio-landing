# =============================================================
# FlowEstudio Landing — Variables de entorno
# =============================================================
#
# Copia este archivo a .env.local para trabajar en local:
#   cp .env.example .env.local
#
# Para producción, crea .env.production con los valores reales.
# Ninguno de esos archivos debe commitearse a git.
#
# Este archivo (.env.example) SÍ se commitea como referencia
# del equipo. No incluyas valores reales aquí.
# =============================================================

# Nombre de la aplicación
VITE_APP_NAME=FlowEstudio

# Entorno actual: development | production
VITE_ENVIRONMENT=development

# URL pública de esta landing
VITE_LANDING_URL=http://localhost:5173

# URL del dashboard / app principal
VITE_DASHBOARD_URL=https://flowestudio-dashbaord.web.app

# URL base del API (backend)
VITE_API_BASE_URL=http://localhost:8000

# Rutas de autenticación
# Login → /login | Registro → /signup | Onboarding inicia en el dashboard
VITE_LOGIN_URL=https://flowestudio-dashbaord.web.app/login
VITE_SIGNUP_URL=https://flowestudio-dashbaord.web.app/signup

# Email de soporte visible en el sitio
VITE_SUPPORT_EMAIL=hola@flowestudio.com
